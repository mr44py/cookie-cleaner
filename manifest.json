{
  "manifest_version": 3,
  "name": "Cookie Sweeper (Whitelist)",
  "version": "1.0",
  "description": "Delete all site data except whitelisted domains.",
  "permissions": [
    "cookies",
    "storage",
    "browsingData"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
